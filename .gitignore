# Tang Political System - Git Ignore

# Runtime data (user-specific)
/data/*.json
/data/*.lock
!/data/.gitkeep

# Python cache
__pycache__/
*.pyc
*.pyo

# Workspace generated files (runtime data, will be regenerated by install script)
/workspaces/
!/workspaces/.gitkeep

# Logs
*.log
logs/

# Output (user-generated content)
output/
!/output/.gitkeep

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Node modules (if any)
node_modules/
